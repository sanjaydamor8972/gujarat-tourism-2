# Local MongoDB OR MongoDB Atlas (replace <password> and use your cluster host)
# MONGO_URI=mongodb://localhost:27017/gujarat_tourism
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.wx9atpl.mongodb.net/gujarat_tourism?appName=Cluster0

# Optional: if SRV DNS fails (querySrv ECONNREFUSED), paste Atlas "Standard connection string" here
# MONGO_URI_STANDARD=mongodb://<username>:<password>@cluster0-shard-00-00.wx9atpl.mongodb.net:27017,.../gujarat_tourism?ssl=true&replicaSet=...

# Set to true for detailed DNS diagnostics on every server start
# MONGO_DEBUG=true

JWT_SECRET=your_jwt_secret_here
PORT=5000
SERVER_URL=http://localhost:5000

# Optional Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
